# ==================== TEST FUNCTIONS ====================

def test_endpoint(name, url, params=None):
    """Test a single endpoint and return results"""
    if params is None:
        params = {}
    
    params['apiKey'] = API_KEY
    
    print(f"\n📡 Testing: {name}")
    print(f"🔗 URL: {url}")
    print(f"📋 Params: {params}")
    
    try:
        start = time.time()
        response = requests.get(url, params=params, timeout=10)
        elapsed = round((time.time() - start) * 1000)
        
        data = response.json()
        status = data.get('status', 'error')
        
        print(f"📊 Status Code: {response.status_code}")
        print(f"⏱️  Response Time: {elapsed}ms")
        print(f"📦 API Status: {status}")
        
        if response.status_code == 200 and status == 'ok':
            total = data.get('totalResults', 0)
            articles = data.get('articles', [])
            sources = data.get('sources', [])
            
            if articles:
                print(f"✅ SUCCESS! Found {total} articles")
                print(f"📰 First article: {articles[0].get('title', 'N/A')[:100]}...")
                return {"success": True, "count": total, "data": articles[:2]}
            elif sources:
                print(f"✅ SUCCESS! Found {len(sources)} sources")
                print(f"📰 First source: {sources[0].get('name', 'N/A')}")
                return {"success": True, "count": len(sources), "data": sources[:2]}
            else:
                print(f"✅ SUCCESS! (No articles)")
                return {"success": True, "count": 0}
        
        elif response.status_code == 401:
            print("❌ UNAUTHORIZED - Invalid API key")
            return {"success": False, "error": "Invalid API key"}
        elif response.status_code == 429:
            print("❌ RATE LIMITED - Too many requests")
            return {"success": False, "error": "Rate limited"}
        elif response.status_code == 400:
            print(f"❌ BAD REQUEST - {data.get('message', 'Unknown error')}")
            return {"success": False, "error": data.get('message', 'Bad request')}
        else:
            print(f"❌ ERROR {response.status_code}: {data.get('message', 'Unknown')}")
            return {"success": False, "error": data.get('message', 'Unknown')}
            
    except requests.exceptions.ConnectionError:
        print("❌ CONNECTION FAILED - Check internet")
        return {"success": False, "error": "Connection failed"}
    except Exception as e:
        print(f"❌ EXCEPTION: {str(e)}")
        return {"success": False, "error": str(e)}

